{
  "Code Block": {
    "prefix": "@cblk",
    "body": [
      "```{${1:python}}",
      "$2",
      "```",
      "$0"
    ],
    "description": "Insert executable code block"
  },
  "Math Block (Equation)": {
    "prefix": "@eqb",
    "body": [
      "\\$\\$",
      "$2",
      "\\$\\$ {#eq-${1:label}}",
      "$0"
    ],
    "description": "Standalone equation block with cross-reference label"
  },
  "Definition": {
    "prefix": "@def",
    "body": [
      "::: {#def-${1:label}}",
      "## ${2:Cross-Reference}",
      "$3",
      ":::",
      "$0"
    ],
    "description": "Insert definition block with cross-reference"
  },
  "Callout": {
    "prefix": "@callout",
    "body": [
      "::: {.callout-${1|note,warning,important,tip,caution|}}",
      "## ${2:Callout Title}",
      "$3",
      ":::",
      "$0"
    ],
    "description": "Insert callout block"
  },
  "Figure": {
    "prefix": "@fig",
    "body": [
      "![${1:Figure caption}](${2:image.png}){#fig-${3:label}}",
      "$0"
    ],
    "description": "Insert image with caption and label"
  }
}
