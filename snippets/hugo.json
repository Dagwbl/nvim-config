{
  "Hugo Shortcode: Bilibili": {
    "prefix": "hg-bilibili",
    "body": "{{< bilibili ${1:BV ID} ${2:1} >}}",
    "description": "Insert bilibili video player (BV, page)"
  },
  "Hugo Shortcode: Douban": {
    "prefix": "hg-douban",
    "body": "{{< douban src=\"${1:https://movie.douban.com/subject/ID/}\" >}}",
    "description": "Insert douban movie/book card"
  },
  "Hugo Shortcode: Encrypt": {
    "prefix": "hg-encrypt",
    "body": [
      "$0",
      "",
      "{{< encrypt${1: hint=\"${2:Original Draft}\"} >}}",
      "$3",
      "{{< /encrypt >}}"
    ],
    "description": "Insert encrypted content block (Backspace to use default hint)"
  },
  "Hugo Shortcode: Music": {
    "prefix": "hg-music",
    "body": "{{< music auto=\"${1:https://music.163.com/#/song?id=ID}\" >}}",
    "description": "Insert music player with auto-detected URL"
  },
  "Hugo Shortcode: YouTube": {
    "prefix": "hg-youtube",
    "body": "{{< youtube ${1:video_id} >}}",
    "description": "Hugo built-in YouTube embed"
  }
}
